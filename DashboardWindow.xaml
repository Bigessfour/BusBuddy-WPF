<Window x:Class="BusBuddy.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BusBuddy Dashboard" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- Navigation Panel -->
        <StackPanel Grid.Column="0" Background="#FF2D3748" Margin="0">
            <TextBlock Text="BusBuddy" FontSize="18" FontWeight="Bold" 
                       Foreground="White" HorizontalAlignment="Center" Margin="10"/>
            <Button x:Name="RoutesButton" Content="Routes" Click="Routes_Click" 
                    Margin="10,5" Padding="10" Background="#FF4A5568" 
                    Foreground="White" BorderThickness="0"/>
            <Button x:Name="BusesButton" Content="Buses" Click="Buses_Click" 
                    Margin="10,5" Padding="10" Background="#FF4A5568" 
                    Foreground="White" BorderThickness="0"/>
            <Button x:Name="DriversButton" Content="Drivers" Click="Drivers_Click" 
                    Margin="10,5" Padding="10" Background="#FF4A5568" 
                    Foreground="White" BorderThickness="0"/>
        </StackPanel>
        
        <!-- Main Content Area -->
        <TabControl x:Name="MainTabControl" Grid.Column="1" 
                    TabStripPlacement="Top" Background="White">
            <TabItem x:Name="RoutesTab" Header="Routes Management">
                <Grid>
                    <TextBlock Text="Routes will be displayed here" 
                               HorizontalAlignment="Center" VerticalAlignment="Center" 
                               FontSize="16" Foreground="Gray"/>
                    <DataGrid x:Name="RoutesGrid" Margin="10" AutoGenerateColumns="True"/>
                </Grid>
            </TabItem>
            <TabItem x:Name="BusesTab" Header="Bus Fleet Management" Visibility="Collapsed">
                <Grid>
                    <TextBlock Text="Bus fleet data will be displayed here" 
                               HorizontalAlignment="Center" VerticalAlignment="Center" 
                               FontSize="16" Foreground="Gray"/>
                    <DataGrid x:Name="BusesGrid" Margin="10" AutoGenerateColumns="True"/>
                </Grid>
            </TabItem>
            <TabItem x:Name="DriversTab" Header="Driver Management" Visibility="Collapsed">
                <Grid>
                    <TextBlock Text="Driver information will be displayed here" 
                               HorizontalAlignment="Center" VerticalAlignment="Center" 
                               FontSize="16" Foreground="Gray"/>
                    <DataGrid x:Name="DriversGrid" Margin="10" AutoGenerateColumns="True"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
