<Window x:Class="BusBuddy.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:BusBuddy.Views"
        Title="BusBuddy Dashboard" Height="600" Width="1000">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Syncfusion.Themes.MaterialDark.WPF;component/Themes/MaterialDark.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <TabControl x:Name="MainTabControl" TabStripPlacement="Left">
            <TabItem Header="Routes">
                <views:RoutesManagementView/>
            </TabItem>
            <TabItem Header="Buses">
                <views:BusesManagementView/>
            </TabItem>
            <TabItem Header="Drivers">
                <views:DriversManagementView/>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
