<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <appSettings>
        <!-- Syncfusion License Key Configuration -->
        <!-- Get your license key from: https://www.syncfusion.com/account/manage-trials/downloads -->
        <!-- For trial users: Get a free 30-day trial license -->
        <!-- For commercial users: Use your licensed key -->
        <add key="SyncfusionLicenseKey" value="" />
    </appSettings>
    
    <connectionStrings>
        <!-- Database connection string for BusBuddy -->
        <add name="BusBuddyConnection" 
             connectionString="Server=localhost;Database=busbuddy;Trusted_Connection=True;MultipleActiveResultSets=True;" 
             providerName="System.Data.SqlClient" />
    </connectionStrings>
</configuration>
